# RF Socket Controller — runtime config.
# Copy to .env on the Pi and edit. systemd loads this via EnvironmentFile=.

# Port the HTTP server binds to (all interfaces by default).
PORT=8080

# Optional HTTPS listener.
#
# ── Recommended: Tailscale (real cert, no browser warnings) ──────────────────
# If you've run deploy/tailscale-https-setup.sh, Caddy handles TLS and this
# should be commented out (the setup script does that for you).
#
# ── Fallback: self-signed (desktop browsers only, iOS may refuse) ─────────────
# Set HTTPS_PORT to enable the app's built-in HTTPS listener.  A self-signed
# cert is auto-generated under data/tls/ on first start.  Desktop browsers
# warn once; iOS Safari and Web Push on iPhones require a real cert — use the
# Tailscale path above instead.
#
# Required if you want getUserMedia (QR scanner) to work in phone browsers.
# Remove or comment out if Caddy (or another reverse proxy) owns TLS.
#HTTPS_PORT=8443

# HTTP Basic Auth. Both must be set to enable auth; leave blank to disable
# (NOT recommended — anyone on your LAN can flip your sockets otherwise).
AUTH_USER=admin
AUTH_PASS=change-me-please

# Cross-origin access. The web UI is served from the same origin as the API,
# so this is unset by default and the browser blocks cross-origin calls. Set
# a comma-separated list of origins to allow another site/app to call the API
# (explicit origins also enable credentialed requests). Leave unset unless you
# know you need it.
#CORS_ALLOWED_ORIGINS=https://home.example.com

# 433MHz transmitter (Nexa self-learning protocol).
# BCM GPIO pin wired to the transmitter module's DATA pin. Requires the
# lgpio Python bindings (Pi OS Bookworm ships them; otherwise:
#   sudo apt install -y python3-lgpio
# No daemon needed — lgpio talks to /dev/gpiochipN directly).
NEXA_TX_GPIO=27

# 433MHz receiver — command the controller spawns to decode incoming
# packets. The process must print one JSON object per line on stdout in
# rtl_433's flat shape: {"model": "...", "id": ..., "<field>": <number>}.
#
# Default is "rtl_433 -F json" (an RTL-SDR USB dongle). Install with:
#   sudo apt install -y rtl-433
# Leave SENSOR_RX_CMD unset to use the default; only set it if you point
# at a different decoder.
#SENSOR_RX_CMD=

# Pi GPIO receiver (ft007th_rx.py — Option A, no dongle needed).
# Only relevant when SENSOR_RX_CMD points at scripts/ft007th_rx.py.
# RF_RX_GPIO  BCM pin wired to the receiver DATA pin   (default 4 → pin 7)
# RF_RX_CHIP  /dev/gpiochipN to open                   (default 0)
#RF_RX_GPIO=4
#RF_RX_CHIP=0

# nRF52840 USB dongle receiver (Option C).
# Set to the CDC ACM device the dongle enumerates as.  Can be active at the
# same time as SENSOR_RX_CMD — both feeds are merged into the same pipeline.
# Leave unset if you are not using the nRF52840 firmware bridge.
#SENSOR_SERIAL_PORT=/dev/ttyACM0

# MQTT broker — enables controlling devices and ingesting sensor readings over
# MQTT. Leave unset (or set to "disabled") to turn the MQTT codepaths off.
#
# This box can run the broker itself: deploy with SETUP_MOSQUITTO=1 (see
# docs/INSTALL.md) to install Mosquitto on the Pi listening on 127.0.0.1:1883,
# or point MQTT_BROKER_URL at an existing broker (Home Assistant, Zigbee2MQTT).
#
# Control: give a socket the "mqtt" protocol and put its command topic in the
# code field (e.g. cmnd/plug/POWER); the controller publishes ON/OFF there.
# Sensors: give a sensor the "mqtt" protocol and put the topic to subscribe to
# in its code field (+/# wildcards allowed).
#MQTT_BROKER_URL=tcp://127.0.0.1:1883
#MQTT_CLIENT_ID=rf-socket-controller
#MQTT_USERNAME=
#MQTT_PASSWORD=
# Set to true only for a broker with a self-signed TLS cert (ssl:// URLs).
#MQTT_TLS_INSECURE=false

# Matter bridge (Node.js sidecar in matter-bridge/) — controls Matter-over-Wi-Fi
# devices like smart bulbs and plugs. Leave at the default loopback URL when
# running both processes on the same Pi. Set to "disabled" to disable the
# Matter codepath entirely (e.g. dev laptop without the bridge running).
MATTER_BRIDGE_URL=http://127.0.0.1:8765

# Network credentials handed to the device during BLE commissioning.
# Both options can be set simultaneously — the commission wizard in the web UI
# will show a "Thread / Wi-Fi" picker when both are configured, so you can
# commission different device types without ever editing this file again.
#
# --- Wi-Fi Matter devices (bulbs, plugs, etc.) ---
# Set to your home Wi-Fi network (2.4 GHz; most Matter devices do not
# support 5 GHz).
MATTER_BRIDGE_WIFI_SSID=YourWiFiNetwork
MATTER_BRIDGE_WIFI_PASS=YourWiFiPassword
#
# --- Thread Matter devices (sensors, some Eve / Aqara / Nanoleaf devices) ---
# Provide the Thread Operational Dataset as a hex TLV string from your
# Thread Border Router (Apple TV 4K, HomePod mini, or an OpenThread BR).
#
# How to get the dataset from an Apple TV 4K / HomePod mini:
#   1. Install the free "Thread" app by the Thread Group on your iPhone/iPad
#      (App Store: https://apps.apple.com/app/thread/id1499524355).
#   2. Open the app — it auto-discovers any Thread Border Router on your LAN
#      and shows its network details.
#   3. Tap "Copy Active Dataset" to copy the hex TLV to your clipboard, then
#      paste it as the value below.
#
#MATTER_BRIDGE_THREAD_DATASET=0e080000000000010000000300001235...
#
# The Thread network name is automatically extracted from the dataset TLV.
# Only set this if the auto-detection fails (it shouldn't in normal use).
#MATTER_BRIDGE_THREAD_NETWORK_NAME=MyThreadNet

# Local LLM assistant — natural-language control + Q&A, powered by a local
# Ollama server. Everything stays on the Pi; nothing is sent to the cloud.
# Disabled by default: the assistant routes return 503 and the UI hides it.
#
# Enable by setting LLM_ENABLED=true after installing Ollama. The deploy
# script can do this for you: run with SETUP_OLLAMA=1 to install Ollama,
# point its model store at a large drive, and pull the model.
#
# Reality check: on a Pi 4 (8 GB, no GPU) a ~3B model answers in seconds to
# tens of seconds. The UI streams so it reads as "thinking", not a hang. You
# can swap LLM_MODEL to a 7B (e.g. qwen2.5:7b-instruct) for stronger results
# at the cost of speed — no code change needed.
#LLM_ENABLED=true
#OLLAMA_URL=http://127.0.0.1:11434
#LLM_MODEL=llama3.2:3b
#LLM_TIMEOUT=120s
