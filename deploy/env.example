# RF Socket Controller — runtime config.
# Copy to .env on the Pi and edit. systemd loads this via EnvironmentFile=.

# Port the HTTP server binds to (all interfaces by default).
PORT=8080

# Optional HTTPS listener. Required if you want the QR scanner to work in
# a phone browser — getUserMedia is blocked outside secure contexts.
# A self-signed cert is generated on first start under data/tls/ and reused
# afterwards. Your browser will warn about it once; accept and continue.
# Remove the line (or comment it out) to disable HTTPS entirely.
HTTPS_PORT=8443

# HTTP Basic Auth. Both must be set to enable auth; leave blank to disable
# (NOT recommended — anyone on your LAN can flip your sockets otherwise).
AUTH_USER=admin
AUTH_PASS=change-me-please

# 433MHz transmitter (Nexa self-learning protocol).
# BCM GPIO pin wired to the transmitter module's DATA pin. Requires the
# lgpio Python bindings (Pi OS Bookworm ships them; otherwise:
#   sudo apt install -y python3-lgpio
# No daemon needed — lgpio talks to /dev/gpiochipN directly).
NEXA_TX_GPIO=27

# 433MHz receiver — command the controller spawns to decode incoming
# packets. The process must print one JSON object per line on stdout in
# rtl_433's flat shape: {"model": "...", "id": ..., "<field>": <number>}.
#
# Default is "rtl_433 -F json" (an RTL-SDR USB dongle). Install with:
#   sudo apt install -y rtl-433
# Leave SENSOR_RX_CMD unset to use the default; only set it if you point
# at a different decoder.
#SENSOR_RX_CMD=

# Matter bridge (Node.js sidecar in matter-bridge/) — controls Matter-over-Wi-Fi
# devices like smart bulbs and plugs. Leave at the default loopback URL when
# running both processes on the same Pi. Set to "disabled" to disable the
# Matter codepath entirely (e.g. dev laptop without the bridge running).
MATTER_BRIDGE_URL=http://127.0.0.1:8765

# Wi-Fi credentials handed to the device during BLE commissioning.
# REQUIRED for Wi-Fi Matter devices (bulbs, plugs, etc.) — without these the
# device cannot join your network and commissioning will fail at the network
# provisioning step. Set to your home Wi-Fi network (2.4 GHz; most Matter
# devices do not support 5 GHz).
MATTER_BRIDGE_WIFI_SSID=YourWiFiNetwork
MATTER_BRIDGE_WIFI_PASS=YourWiFiPassword
